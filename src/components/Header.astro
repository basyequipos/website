---
import { SITE_TITLE } from "../consts";
import Logo from "../assets/icons/basyequipos.svg";
import Navigation from "./Navigation.astro";
import MenuIcon from "../assets/icons/menu.svg";
import CloseIcon from "../assets/icons/x.svg";
---

<header>
    <div class="wide-container">
        <a href="/" class="brand">
            <Logo />
            <p>{SITE_TITLE.toUpperCase()}</p>
        </a>

        <Navigation class="header-desktop" />
        <button
            id="menu-toggle"
            type="button"
            aria-label="Abrir menú"
            aria-expanded="false"
            aria-controls="mobile-menu"
        >
            <MenuIcon class="menu-icon" />
            <CloseIcon class="close-icon" />
        </button>
    </div>

    <div id="mobile-menu" class="mobile-menu">
        <Navigation class="header-mobile" />
    </div>
</header>

<style>
    header {
        background-color: var(--surface);
        border-bottom: 1px solid var(--outline);
        width: 100%;
        position: relative;
        z-index: 100;
    }

    button {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        margin-left: auto;
        padding: 0;
    }

    .mobile-menu {
        display: none;
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 1rem;
        text-decoration: none;
        color: inherit;
    }

    .brand svg {
        height: 3rem;
    }

    .brand p {
        margin: 0;
        padding: 0;
        font-size: 1.5rem;
        font-weight: 700;
    }

    .wide-container {
        display: flex;
        align-items: center;
        padding: 1rem;
    }

    button .close-icon {
        display: none;
    }

    button[aria-expanded="true"] .menu-icon {
        display: none;
    }

    button[aria-expanded="true"] .close-icon {
        display: block;
    }

    @media (max-width: 767px) {
        svg {
            height: 2rem;
        }

        button {
            display: block;
            margin-left: auto;
        }

        :global(.header-desktop) {
            display: none;
        }

        header:has(button[aria-expanded="true"]) .mobile-menu {
            display: block;
            position: absolute;
            background-color: var(--surface, white);
            top: 100%; /* Cero huecos: se pega exactamente al final del header */
            left: 0;
            width: 100%;
            /* Solución al scroll fantasma: usamos una altura fija basada en la pantalla */
            height: 100vh;
            height: 100svh;
            z-index: 99;
            overflow-y: auto;
            padding: 2rem;
        }
    }
</style>

<script>
    const menuToggle = document.getElementById("menu-toggle");

    if (menuToggle) {
        menuToggle.addEventListener("click", () => {
            const isExpanded =
                menuToggle.getAttribute("aria-expanded") === "true";
            menuToggle.setAttribute("aria-expanded", String(!isExpanded));
            menuToggle.setAttribute(
                "aria-label",
                isExpanded ? "Abrir menú" : "Cerrar menú",
            );

            // Solución definitiva para congelar el fondo en móviles reales
            if (!isExpanded) {
                document.documentElement.style.overflow = "hidden";
                document.body.style.overflow = "hidden";
            } else {
                document.documentElement.style.overflow = "";
                document.body.style.overflow = "";
            }
        });
    }
</script>
